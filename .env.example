# Copy this file to .env and fill in real values before running docker-compose

# Postgres
POSTGRES_USER=rcm
POSTGRES_PASSWORD=rcm_dev_password
POSTGRES_DB=rcm
DATABASE_URL=postgresql+psycopg2://rcm:rcm_dev_password@postgres:5432/rcm

# MongoDB (Brick 2 - clinical notes)
MONGO_URL=mongodb://mongo:27017
MONGO_DB=rcm

# AI engine (Claude). Without this, AI analysis endpoints return a clear
# "AI engine unavailable" error instead of crashing the app.
ANTHROPIC_API_KEY=

# Frontend — backend address as seen from inside the frontend container
# (Vite dev-server proxy target). Browser only talks to the Vite server on :5173.
BACKEND_URL=http://backend:8000
